{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WeatherForecast",
  "type": "object",
  "required": ["cod", "message", "cnt", "list", "city"],
  "properties": {
    "cod": { "type": ["string", "integer"] },
    "message": { "type": ["number", "string"] },
    "cnt": { "type": "integer", "minimum": 0 },
    "list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dt", "main", "weather", "clouds", "wind", "visibility", "pop", "sys", "dt_txt"],
        "properties": {
          "dt": { "type": "integer" },
          "main": {
            "type": "object",
            "required": ["temp", "feels_like", "temp_min", "temp_max", "pressure", "humidity"],
            "properties": {
              "temp": { "type": "number" },
              "feels_like": { "type": "number" },
              "temp_min": { "type": "number" },
              "temp_max": { "type": "number" },
              "pressure": { "type": "integer" },
              "sea_level": { "type": "integer" },
              "grnd_level": { "type": "integer" },
              "humidity": { "type": "integer", "minimum": 0, "maximum": 100 },
              "temp_kf": { "type": "number" }
            },
            "additionalProperties": false
          },
          "weather": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "main", "description", "icon"],
              "properties": {
                "id": { "type": "integer" },
                "main": { "type": "string" },
                "description": { "type": "string" },
                "icon": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "clouds": {
            "type": "object",
            "required": ["all"],
            "properties": {
              "all": { "type": "integer", "minimum": 0, "maximum": 100 }
            },
            "additionalProperties": false
          },
          "wind": {
            "type": "object",
            "required": ["speed", "deg"],
            "properties": {
              "speed": { "type": "number" },
              "deg": { "type": "number", "minimum": 0, "maximum": 360 },
              "gust": { "type": "number" }
            },
            "additionalProperties": false
          },
          "visibility": { "type": "integer" },
          "pop": { "type": "number", "minimum": 0, "maximum": 1 },
          "rain": {
            "type": "object",
            "properties": {
              "3h": { "type": "number" }
            },
            "additionalProperties": false
          },
          "snow": {
            "type": "object",
            "properties": {
              "3h": { "type": "number" }
            },
            "additionalProperties": false
          },
          "sys": {
            "type": "object",
            "required": ["pod"],
            "properties": {
              "pod": { "type": "string", "enum": ["d", "n"] }
            },
            "additionalProperties": false
          },
          "dt_txt": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "city": {
      "type": "object",
      "required": ["id", "name", "coord", "country", "population", "timezone", "sunrise", "sunset"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "coord": {
          "type": "object",
          "required": ["lat", "lon"],
          "properties": {
            "lat": { "type": "number", "minimum": -90, "maximum": 90 },
            "lon": { "type": "number", "minimum": -180, "maximum": 180 }
          },
          "additionalProperties": false
        },
        "country": { "type": "string" },
        "population": { "type": "integer" },
        "timezone": { "type": "integer" },
        "sunrise": { "type": "integer" },
        "sunset": { "type": "integer" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
